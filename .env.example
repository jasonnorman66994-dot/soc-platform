# ============================================================
# Environment configuration — copy to .env and fill in values
# DO NOT commit a populated .env file to version control
# ============================================================

# --- Secrets (required — generate strong random values for production) ---
# Example: openssl rand -hex 32
JWT_SECRET=replace-with-strong-random-value
ADMIN_SESSION_SECRET=replace-with-strong-random-value
INTERNAL_ADMIN_TOKEN=replace-with-admin-token

# --- Stripe (leave blank to disable Stripe webhook verification) ---
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
WEBHOOK_REPLAY_TTL_DAYS=7

# --- Security flags ---
# Set STRICT_SECURITY_MODE=true in production to refuse startup with insecure defaults
STRICT_SECURITY_MODE=false
# Set ENFORCE_HTTPS=true and ALLOW_INSECURE_HTTP=false in production
ENFORCE_HTTPS=false
ALLOW_INSECURE_HTTP=false

# --- Services ---
DATABASE_URL=postgresql://soc:socpass@db:5432/socdb
REDIS_URL=redis://redis:6379/0
